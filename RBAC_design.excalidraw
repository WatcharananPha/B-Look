    {
      "id": "bdwgXL9Vsc5ztI4E6ogQq",
      "type": "text",
      "x": 3153.0296880636974,
      "y": 3821.073148089618,
      "width": 1304.9025472005203,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
